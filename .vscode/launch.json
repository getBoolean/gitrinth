{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Neoforge: Get",
            "request": "launch",
            "type": "dart",
            "program": "bin/gitrinth.dart",
            "args": [
                "get",
                "--directory=example/example_neoforge"
            ]
        },
        {
            "name": "Neoforge: Build",
            "request": "launch",
            "type": "dart",
            "program": "bin/gitrinth.dart",
            "args": [
                "build",
                "--directory=example/example_neoforge"
            ]
        },
        {
            "name": "Neoforge: Client",
            "request": "launch",
            "type": "dart",
            "program": "bin/gitrinth.dart",
            "args": [
                "launch",
                "client",
                "--directory=example/example_neoforge",
                "--memory=4G"
            ]
        },
        {
            "name": "Neoforge: Server",
            "request": "launch",
            "type": "dart",
            "program": "bin/gitrinth.dart",
            "args": [
                "launch",
                "server",
                "--directory=example/example_neoforge",
                "--accept-eula",
                "--memory=4G",
                "--detach"
            ]
        }
    ]
}